# whisper.cpp 실행 파일 경로
# 실제 설치 경로의 절대경로로 바꿔야 합니다.
WHISPER_CPP_BIN=./whisper.cpp/build/bin/whisper-cli

# whisper.cpp 모델 파일 경로
# 실제 모델 파일의 절대경로로 바꿔야 합니다.
WHISPER_MODEL_PATH=./whisper.cpp/models/ggml-base.en.bin

# 인식 언어
WHISPER_LANGUAGE=en

# 1이면 GPU 비활성화, 0이면 GPU 사용 시도
WHISPER_NO_GPU=0

# 아래 값들은 필요하면 조정
PARTIAL_UPDATE_INTERVAL_SECONDS=1.0
MIN_PARTIAL_AUDIO_SECONDS=1.0
END_GRACE_SECONDS=0.6
STABLE_WORD_COUNT_THRESHOLD=3
STABLE_WORD_AGE_SECONDS=0.3
